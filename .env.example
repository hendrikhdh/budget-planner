# Firebase-Konfiguration
# Kopiere diese Datei zu .env.local und trage deine eigenen Werte ein.
# WICHTIG: .env.local NIEMALS committen oder teilen!
# Die Werte findest du in der Firebase Console unter Projekteinstellungen.

VITE_FIREBASE_API_KEY=dein-api-key-hier
VITE_FIREBASE_AUTH_DOMAIN=dein-projekt.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=dein-projekt-id
VITE_FIREBASE_STORAGE_BUCKET=dein-projekt.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
